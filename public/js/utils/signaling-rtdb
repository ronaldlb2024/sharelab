// Sinalização WebRTC usando Firebase Realtime Database (RTDB)

function toJSONCandidate(c) { return c && c.toJSON ? c.toJSON() : c; }
function is4Digits(code) { return /^\d{4}$/.test(String(code || '').trim()); }

// Pequeno helper para desinscrever com segurança
async function safeOff(ref, event, cb) {
  try { ref && ref.off && cb && ref.off(event, cb); } catch {}
}

export async function createSession(code, pc, db) {
  if (!is4Digits(code)) throw new Error('Código inválido. Use 4 dígitos.');
  const roomRef = db.ref('sessions').child(code);

  const offerSnap = await roomRef.child('offer').get();
  if (offerSnap.exists()) throw new Error('Código em uso. Gere outro.');

  // Marca presença do caller (limpeza automática se a aba cair)
  const callerRef = roomRef.child('participants/caller');
  await callerRef.set(true);
  callerRef.onDisconnect().remove().catch(()=>{});

  // ICE candidates do caller
  const callerCandsRef = roomRef.child('callerCandidates');
  callerCandsRef.onDisconnect().remove().catch(()=>{});

  pc.onicecandidate = (ev) => {
    if (ev.candidate) callerCandsRef.push(toJSONCandidate(ev.candidate));
  };

  // Cria a offer
  const offer = await pc.createOffer();
  await pc.setLocalDescription(offer);

  await roomRef.update({
    offer: { type: offer.type, sdp: offer.sdp },
    createdAt: firebase.database.ServerValue.TIMESTAMP,
    // TTL “informativo” (10 min). Reforce nas regras do RTDB/Cloud Function se quiser expurgo real.
    ttlAt: Date.now() + 10 * 60 * 1000,
    state: 'waiting-answer'
  });

  // Aguarda a answer do médico
  const answerRef = roomRef.child('answer');
  const onAnswer = answerRef.on('value', async (snap) => {
    const ans = snap.val();
    if (!ans) return;
    if (!pc.currentRemoteDescription) {
      await pc.setRemoteDescription(new RTCSessionDescription(ans));
      roomRef.child('state').set('connected').catch(()=>{});
    }
  });

  // Recebe ICE do callee
  const calleeCandsRef = roomRef.child('calleeCandidates');
  const onCallee = calleeCandsRef.on('child_added', (snap) => {
    const data = snap.val();
    if (data) pc.addIceCandidate(new RTCIceCandidate(data)).catch(()=>{});
  });

  // Limpeza posterior
  pc.__signalingCleanup = async () => {
    await safeOff(answerRef, 'value', onAnswer);
    await safeOff(calleeCandsRef, 'child_added', onCallee);
    try { const s = await callerCandsRef.get(); s.forEach(d => d.ref.remove()); } catch {}
    // Não removemos a sala aqui para permitir o médico conectar/ler.
  };

  // Fechamento → marca presença encerrada
  pc.addEventListener('iceconnectionstatechange', () => {
    const st = pc.iceConnectionState;
    if (st === 'failed' || st === 'disconnected' || st === 'closed') {
      try { pc.__signalingCleanup?.(); } catch {}
    }
  });

  return code;
}

export async function joinSession(code, pc, db) {
  if (!is4Digits(code)) throw new Error('Código inválido. Use 4 dígitos.');
  const roomRef = db.ref('sessions').child(code);
  const roomSnap = await roomRef.get();

  if (!roomSnap.exists() || !roomSnap.child('offer').exists())
    throw new Error('Código inválido ou sessão expirada.');

  // Marca presença do callee (limpeza automática)
  const calleeRef = roomRef.child('participants/callee');
  await calleeRef.set(true);
  calleeRef.onDisconnect().remove().catch(()=>{});

  const calleeCandsRef = roomRef.child('calleeCandidates');
  calleeCandsRef.onDisconnect().remove().catch(()=>{});

  pc.onicecandidate = (ev) => {
    if (ev.candidate) calleeCandsRef.push(toJSONCandidate(ev.candidate));
  };

  // Seta a offer do paciente
  const offer = roomSnap.child('offer').val();
  await pc.setRemoteDescription(new RTCSessionDescription(offer));

  // Cria a answer do médico
  const answer = await pc.createAnswer();
  await pc.setLocalDescription(answer);
  await roomRef.child('answer').set({ type: answer.type, sdp: answer.sdp });
  await roomRef.child('state').set('connected').catch(()=>{});

  // Recebe ICE do caller
  const callerCandsRef = roomRef.child('callerCandidates');
  const onCaller = callerCandsRef.on('child_added', (snap) => {
    const data = snap.val();
    if (data) pc.addIceCandidate(new RTCIceCandidate(data)).catch(()=>{});
  });

  pc.__signalingCleanup = async () => {
    await safeOff(callerCandsRef, 'child_added', onCaller);
    try { const s = await calleeCandsRef.get(); s.forEach(d => d.ref.remove()); } catch {}
  };

  pc.addEventListener('iceconnectionstatechange', () => {
    const st = pc.iceConnectionState;
    if (st === 'failed' || st === 'disconnected' || st === 'closed') {
      try { pc.__signalingCleanup?.(); } catch {}
    }
  });

  return code;
}
